{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "declaration": false,
    "incremental": false,
    "isolatedModules": false,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "noEmit": false,
    "outDir": ".tmp/test",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["src/lib/assessment/**/*.ts", "src/lib/utils/**/*.ts", "tests/**/*.test.ts"],
  "exclude": ["node_modules", ".next"]
}
